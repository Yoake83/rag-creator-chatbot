# ── LLM + Embeddings ──────────────────────────────
OPENAI_API_KEY=sk-...

# ── Vector DB ─────────────────────────────────────
# ChromaDB (default, local — no extra setup)
CHROMA_PERSIST_DIR=./chroma_db

# Uncomment to use Qdrant instead (for production)
# VECTOR_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Instagram / Social ────────────────────────────
# Apify token for Instagram metadata (free tier = 5 actors/mo)
APIFY_TOKEN=

# RapidAPI key — fallback for Instagram metadata
RAPIDAPI_KEY=

# ── Transcript ────────────────────────────────────
# Set to "whisper" to force Whisper for all audio (slower, more accurate)
# Set to "auto" (default) to use captions when available
TRANSCRIPT_BACKEND=auto

# ── App ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ── Frontend (copy to frontend/.env.local) ────────
VITE_API_URL=http://localhost:8000
